def main():
    parser = argparse.ArgumentParser(prog="mito", description="Mito - The Powerhouse CLI")
    parser.add_argument("-v", "--version", action="store_true", help="Show version")
    parser.add_argument("-l", "--list", action="store_true", help="List all tools")

    subparsers = parser.add_subparsers(dest="command", help="Command to run")

    # --- Llama ---
    p = subparsers.add_parser("llama", help="Run Llama inference")
    p.add_argument("model")
    p.add_argument("prompt")
    p.add_argument("--tokens", type=int)
    p.add_argument("--temp", type=float)
    p.add_argument("--ctx", type=int)
    p.add_argument("-t", "--threads", type=int)

    # --- OCR ---
    p = subparsers.add_parser("ocr", help="OCR text recognition")
    p.add_argument("image")

    # --- Textgen ---
    p = subparsers.add_parser("textgen", help="Text generation")
    p.add_argument("prompt", nargs="+")
    p.add_argument("--model")
    p.add_argument("--tokens", type=int)

    # --- Classify ---
    p = subparsers.add_parser("classify", help="Image classification")
    p.add_argument("image")
    p.add_argument("--top-k", type=int, default=5)

    # --- Sentiment ---
    p = subparsers.add_parser("sentiment", help="Sentiment analysis")
    p.add_argument("text", nargs="+")

    # --- Speech ---
    p = subparsers.add_parser("speech", help="Speech recognition")
    p.add_argument("audio")
    p.add_argument("--model", default="base")

    # --- Translate ---
    p = subparsers.add_parser("translate", help="Translation")
    p.add_argument("text", nargs="+")
    p.add_argument("--model")

    # --- Embed ---
    p = subparsers.add_parser("embed", help="Text embeddings")
    p.add_argument("text", nargs="+")
    p.add_argument("--model")

    # --- Summarize ---
    p = subparsers.add_parser("summarize", help="Text summarization")
    p.add_argument("text", nargs="+")
    p.add_argument("--max-length", type=int, default=130)

    # --- QA ---
    p = subparsers.add_parser("qa", help="Question answering")
    p.add_argument("question")
    p.add_argument("context", nargs="+")

    # --- TTS ---
    p = subparsers.add_parser("tts", help="Text-to-speech")
    p.add_argument("text", nargs="+")
    p.add_argument("--output", "-o")

    # --- RAG ---
    p = subparsers.add_parser("rag", help="RAG question answering")
    p.add_argument("--query")
    p.add_argument("--add")
    p.add_argument("--save")

    # --- Agent (plain ReAct) ---
    p = subparsers.add_parser("agent", help="ReAct agent (plain)")
    p.add_argument("task")
    p.add_argument("--model")
    p.add_argument("--max-iterations", type=int)
    p.add_argument("--metrics", action="store_true", help="Show execution metrics")
    p.add_argument("--plugins", nargs="+", default=[],
                   help="Load plugins: file_ops, web_search, database, git_ops, shell, http_api, json_ops, env_ops, all")

    # --- LRS Agent (Active Inference) ---
    p = subparsers.add_parser("lrs-agent", help="LRS agent (Active Inference, resilient)")
    p.add_argument("task")
    p.add_argument("--model")
    p.add_argument("--max-iterations", type=int)
    p.add_argument("--lrs-proposals", type=int, help="Number of policy proposals per step (default: 5)")
    p.add_argument("--lrs-threshold", type=float, help="Precision threshold for adaptation (default: 0.4)")
    p.add_argument("--no-adaptation", action="store_true", help="Disable automatic adaptation")
    p.add_argument("--pref-success", type=float, help="Reward weight for success (default: 5.0)")
    p.add_argument("--pref-error", type=float, help="Penalty weight for error (default: -3.0)")
    p.add_argument("--metrics", action="store_true", help="Show LRS metrics")
    p.add_argument("--verbose", action="store_true", help="Show detailed precision history")
    p.add_argument("--plugins", nargs="+", default=[],
                   help="Load plugins: file_ops, web_search, database, git_ops, shell, http_api, json_ops, env_ops, all")

    # --- Plan ---
    p = subparsers.add_parser("plan", help="Multi-step planner agent")
    p.add_argument("goal")
    p.add_argument("--constraint", action="append", dest="constraint",
                   help="Add a constraint (repeat for multiple)")
    p.add_argument("--steps", action="append",
                   help="Custom step descriptions (repeat for multiple)")
    p.add_argument("--execute", action="store_true", help="Execute the plan after creation")
    p.add_argument("--metrics", action="store_true", help="Show plan metrics")
    p.add_argument("--name", default="Planner")

    # --- Build ---
    p = subparsers.add_parser("build", help="Code generation / review / refactor agent")
    p.add_argument("prompt", nargs="?", default="", help="Code generation prompt")
    p.add_argument("--language", "-l", help="Programming language (default: python)")
    p.add_argument("--review", help="Review code in this file")
    p.add_argument("--refactor", help="Refactor code in this file")
    p.add_argument("--strategy", default="extract",
                   choices=["extract", "inline", "rename", "split"],
                   help="Refactoring strategy (default: extract)")
    p.add_argument("--name", default="Builder")

    # --- Chat ---
    p = subparsers.add_parser("chat", help="Interactive chat")
    p.add_argument("model", nargs="?", default="model.gguf")

    # --- Server ---
    p = subparsers.add_parser("server", help="Start API server")
    p.add_argument("--host")
    p.add_argument("--port", type=int)

    args = parser.parse_args()

    if args.version:
        print(f"mito v{VERSION}")
        return

    if args.list or not args.command:
        cmd_list(args)
        return

    if hasattr(args, 'prompt') and isinstance(args.prompt, list):
        args.prompt = " ".join(args.prompt)
    if hasattr(args, 'text') and isinstance(args.text, list):
        args.text = " ".join(args.text)
    if hasattr(args, 'context') and isinstance(args.context, list):
        args.context = " ".join(args.context)

    commands = {
        "llama": cmd_llama,
        "ocr": cmd_ocr,
        "textgen": cmd_textgen,
        "classify": cmd_classify,
        "sentiment": cmd_sentiment,
        "speech": cmd_speech,
        "translate": cmd_translate,
        "embed": cmd_embed,
        "summarize": cmd_summarize,
        "qa": cmd_qa,
        "tts": cmd_tts,
        "rag": cmd_rag,
        "agent": cmd_agent,
        "lrs-agent": cmd_lrs_agent,
        "plan": cmd_plan,
        "build": cmd_build,
        "chat": cmd_chat,
        "server": cmd_server,
    }

    if args.command in commands:
        try:
            commands[args.command](args)
        except Exception as e:
            import traceback
            print(f"Error: {e}", file=sys.stderr)
            if "--verbose" in sys.argv or getattr(args, 'verbose', False):
                traceback.print_exc()
            sys.exit(1)
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
