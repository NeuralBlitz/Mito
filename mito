def _load_agent_tools(enabled_plugins=None):
    """Load real tools from python.ai modules and plugin integrations."""
    from agents import Tool

    tools = []

    def safe_tool(name, desc, func, schema=None):
        try:
            tools.append(Tool(
                name=name,
                description=desc,
                func=func,
                input_schema=schema or {"type": "object"},
                tags=["builtin"],
            ))
        except Exception:
            pass

    def _extract_from_thought(tool_name: str, thought: str) -> dict:
        """Extract meaningful parameters from the full thought text for a specific tool."""
        lines = [l.strip() for l in thought.split("\n") if l.strip()]
        result = {}

        for line in lines:
            if tool_name in line.lower():
                continue
            for kw in ("text:", "prompt:", "expr:", "question:", "context:"):
                if kw in line.lower():
                    val = line.lower().split(kw, 1)[1].strip().strip("'\"").strip()
                    key = kw.rstrip(":")
                    result[key] = val

        if "input" in thought and not result:
            input_start = thought.lower().find("input")
            if input_start >= 0:
                snippet = thought[input_start:input_start + 300]
                for sep in [",", "\n", ". "]:
                    if sep in snippet:
                        val = snippet.split(sep, 1)[0].split("input", 1)[1].strip().strip(":\'\"").strip()
                        if val and len(val) > 1:
                            result["text"] = val
                            break

        return result

    def textgen_tool(**kwargs) -> str:
        from python.ai import TextGenerator
        prompt = kwargs.get("prompt") or kwargs.get("input") or kwargs.get("text") or ""
        model = kwargs.get("model") or "gpt2"
        max_length = int(kwargs.get("max_length") or 200)
        if len(prompt) < 5:
            prompt = "Respond to the user's request."
        gen = TextGenerator(model_name=model)
        return gen.generate_single(prompt, max_length=max_length)

    def summarize_tool(**kwargs) -> str:
        from python.ai.summarize import Summarizer
        text = kwargs.get("text") or kwargs.get("input") or ""
        max_length = int(kwargs.get("max_length") or 130)
        if len(text) < 10:
            return "[No text to summarize]"
        summ = Summarizer()
        return summ.summarize(text, max_length=max_length)

    def sentiment_tool(**kwargs) -> str:
        from python.ai.sentiment import quick_sentiment
        text = kwargs.get("text") or kwargs.get("input") or ""
        if len(text) < 2:
            return "[No text for sentiment analysis]"
        result = quick_sentiment(text)
        return f"Sentiment: {result['label']} ({result['score']:.4f})"

    def embed_tool(**kwargs) -> str:
        from python.ai.embeddings import Embedder
        text = kwargs.get("text") or kwargs.get("input") or ""
        model = kwargs.get("model") or "sentence-transformers/all-MiniLM-L6-v2"
        if len(text) < 2:
            return "[No text for embedding]"
        embedder = Embedder(model_name=model)
        emb = embedder.embed(text)
        return f"Embedding dimension: {len(emb)}, first 5: {emb[:5]}"

    def calc_tool(**kwargs) -> str:
        expr = kwargs.get("expr") or kwargs.get("input") or ""
        import re
        numbers = re.findall(r'-?\d+\.?\d*', expr)
        ops = re.findall(r'[+\-*/^%]', expr)
        if not numbers:
            numbers = re.findall(r'\d+', expr)
        if numbers and ops:
            clean = ''.join(c for c in expr if c.isdigit() or c in '+-*/.() ' or c == '**')
            try:
                result = eval(clean)
                return str(result)
            except Exception:
                pass
        if numbers:
            if len(numbers) >= 2 and ops:
                a, b = float(numbers[0]), float(numbers[1])
                op = ops[0] if ops else '+'
                if op == '+': return str(a + b)
                if op == '-': return str(a - b)
                if op == '*': return str(a * b)
                if op == '/': return str(a / b if b else "division by zero")
        return f"[Could not extract calculation from: {expr[:100]}]"

    def qa_tool(**kwargs) -> str:
        from python.ai.qa import QAModel
        question = kwargs.get("question") or kwargs.get("input") or ""
        context = kwargs.get("context") or ""
        if not question:
            return "[No question provided]"
        if not context:
            context = question
        qa = QAModel()
        result = qa.answer(question, context)
        return f"Answer: {result['answer']} (score: {result['score']:.4f})"

    safe_tool("textgen", "Generate text using an LLM", textgen_tool,
              {"type": "object", "properties": {
                  "prompt": {"type": "string"},
                  "model": {"type": "string"},
                  "max_length": {"type": "integer"}
              }, "required": ["prompt"]})

    safe_tool("summarize", "Summarize long text", summarize_tool,
              {"type": "object", "properties": {
                  "text": {"type": "string"},
                  "max_length": {"type": "integer"}
              }, "required": ["text"]})

    safe_tool("sentiment", "Analyze sentiment of text", sentiment_tool,
              {"type": "object", "properties": {
                  "text": {"type": "string"}
              }, "required": ["text"]})

    safe_tool("embed", "Create text embeddings", embed_tool,
              {"type": "object", "properties": {
                  "text": {"type": "string"},
                  "model": {"type": "string"}
              }, "required": ["text"]})

    safe_tool("calculator", "Evaluate mathematical expressions", calc_tool,
              {"type": "object", "properties": {
                  "expr": {"type": "string"}
              }, "required": ["expr"]})

    safe_tool("qa", "Answer questions given context", qa_tool,
              {"type": "object", "properties": {
                  "question": {"type": "string"},
                  "context": {"type": "string"}
              }, "required": ["question", "context"]})

    enabled_plugins = enabled_plugins or []
    plugin_tools = _load_plugin_tools(enabled_plugins)
    tools.extend(plugin_tools)

    return tools


def _load_plugin_tools(plugin_names):
    """Load tools from named plugin integrations."""
    from agents import Tool

    tools = []

    def safe_tool(name, desc, func, schema=None):
        try:
            tools.append(Tool(
                name=name,
                description=desc,
                func=func,
                input_schema=schema or {"type": "object"},
                tags=["plugin"],
            ))
        except Exception:
            pass

    plugin_map = {
        "file_ops": ("plugins.integrations.file_ops", "file_ops_plugin"),
        "web_search": ("plugins.integrations.web_search", "web_search_plugin"),
        "database": ("plugins.integrations.database", "database_plugin"),
        "git_ops": ("plugins.integrations.git_ops", "git_ops_plugin"),
        "shell": ("plugins.integrations.shell", "shell_plugin"),
        "http_api": ("plugins.integrations.http_api", "http_api_plugin"),
        "json_ops": ("plugins.integrations.json_ops", "json_ops_plugin"),
        "env_ops": ("plugins.integrations.env_ops", "env_ops_plugin"),
    }

    if "all" in plugin_names:
        plugin_names = list(plugin_map.keys())

    loaded = []
    for name in plugin_names:
        if name not in plugin_map:
            print(f"Warning: Unknown plugin '{name}'", file=sys.stderr)
            continue
        mod_path, plugin_attr = plugin_map[name]
        try:
            mod = __import__(mod_path, fromlist=[plugin_attr])
            plugin_obj = getattr(mod, plugin_attr)
            meta = plugin_obj.get("metadata", {})
            register_fn = plugin_obj.get("register")

            class FakePlugin:
                def __init__(self):
                    self._commands = {}
                def register_command(self, cmd_name, cmd_func):
                    self._commands[cmd_name] = cmd_func
                def set_resource(self, key, val):
                    setattr(self, key, val)
                def get_commands(self):
                    return self._commands

            fp = FakePlugin()
            if register_fn:
                register_fn(fp)
            for cmd_name, cmd_func in fp.get_commands().items():
                safe_tool(cmd_name, f"[{name}] {cmd_name}", cmd_func,
                          {"type": "object", "properties": {}})
            loaded.append(name)
        except Exception as e:
            print(f"Warning: Failed to load plugin '{name}': {e}", file=sys.stderr)

    if loaded:
        print(f"[plugins] Loaded: {', '.join(loaded)}")

    return tools


