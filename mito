def cmd_lrs_agent(args):
    """LRS agent (Active Inference) with precision tracking and automatic adaptation."""
    tools = _load_agent_tools(enabled_plugins=args.plugins)
    if not tools:
        print("Error: No tools available. Check python.ai module imports.", file=sys.stderr)
        sys.exit(1)

    from agents import LRSReActAgent

    model = args.model or "gpt2"
    max_iters = args.max_iterations or 5
    num_proposals = args.lrs_proposals or 5
    precision_threshold = args.lrs_threshold or 0.4
    adaptation = not args.no_adaptation
    preferences = {"success": args.pref_success or 5.0, "error": args.pref_error or -3.0}

    try:
        agent = LRSReActAgent(
            name="MitoLRS",
            role="Resilient AI assistant (Active Inference)",
            tools=tools,
            model=model,
            num_proposals=num_proposals,
            precision_threshold=precision_threshold,
            adaptation_enabled=adaptation,
            preferences=preferences,
        )
    except ImportError as e:
        print(f"Error: lrs-agents not installed. Run: pip install lrs-agents", file=sys.stderr)
        print(f"Detail: {e}", file=sys.stderr)
        sys.exit(1)

    print(f"[lrs-agent] Active Inference agent | {len(tools)} tools | model={model}")
    print(f"[lrs-agent] Proposals: {num_proposals} | Precision threshold: {precision_threshold}")
    print(f"[lrs-agent] Adaptation: {'enabled' if adaptation else 'disabled'} | Preferences: {preferences}")
    print(f"[lrs-agent] Tools: {', '.join(t.name for t in tools)}\n")

    result = agent.run(args.task, max_iterations=max_iters)
    print(result)

    if args.metrics or args.verbose:
        lrs = agent.get_lrs_metrics()
        print(f"\n--- LRS Metrics ---")
        print(f"  Version: {lrs.get('lrs_version', 'n/a')}")
        print(f"  Adaptation count: {lrs.get('adaptation_count', 0)}")
        prec = lrs.get('precision', {})
        if isinstance(prec, dict):
            for level, val in prec.items():
                print(f"  Precision [{level}]: {val:.4f}")
        elif isinstance(prec, (int, float)):
            print(f"  Precision: {prec:.4f}")
        print(f"  Proposals generated: {lrs.get('proposals_generated', 0)}")
        selected = lrs.get('selected_policy', {})
        if selected.get('tool'):
            print(f"  Selected policy: {selected.get('tool')} (G={selected.get('g_value', 0):.4f})")
        failed = lrs.get('failed_tools', {})
        if failed:
            print(f"  Failed tools: {failed}")
        lens_stats = lrs.get('tool_lens_stats', {})
        if lens_stats:
            print(f"  Tool lens stats:")
            for name, stats in lens_stats.items():
                print(f"    {name}: calls={stats.get('call_count', 0)}, "
                      f"failures={stats.get('failure_count', 0)}, "
                      f"success_rate={stats.get('success_rate', 0):.2f}")

        if args.verbose and lrs.get('precision_history'):
            print(f"\n--- Precision History ({len(lrs['precision_history'])} events) ---")
            for ev in lrs['precision_history'][-5:]:
                print(f"  [{ev.get('level')}] {ev.get('old_precision', 0):.3f} -> "
                      f"{ev.get('new_precision', 0):.3f} | {ev.get('reason', '')}")


def cmd_plan(args):
    """Plan agent: decompose goals into structured multi-step plans."""
    from agents import PlannerAgent

    agent = PlannerAgent(name=args.name or "Planner")

    print(f"[plan] Creating plan for: {args.goal}\n")

    steps = agent.plan(
        goal=args.goal,
        constraints=args.constraint if args.constraint else None,
        custom_steps=args.steps if args.steps else None,
    )

    print("=== Plan ===")
    for step in steps:
        status_icon = {"pending": "○", "completed": "●", "failed": "✗"}.get(step.get("status"), "?")
        print(f"  {status_icon} Step {step['step']}: {step['action']}")

    if args.execute:
        print(f"\n[plan] Executing plan...")
        result = agent.execute_plan(plan_index=0)
        print(f"\n=== Execution Result ===")
        print(f"  Goal: {result.get('goal', '')}")
        print(f"  Completed: {result.get('completed', False)}")
        completed = sum(1 for s in result.get('steps', []) if s.get('status') == 'completed')
        print(f"  Steps completed: {completed}/{len(result.get('steps', []))}")

    if args.metrics:
        print(f"\n--- Metrics ---")
        status = agent.get_plan_status(0)
        print(f"  Goal: {status.get('goal', '')}")
        print(f"  Status: {status.get('status', '')}")
        print(f"  Progress: {status.get('progress', '')}")


def cmd_build(args):
    """Build agent: generate, review, and refactor code."""
    from agents import CodeAgent

    language = args.language or "python"
    agent = CodeAgent(name=args.name or "Builder")

    if args.review:
        print(f"[build] Reviewing code from: {args.review}\n")
        try:
            with open(args.review, 'r') as f:
                code = f.read()
        except Exception as e:
            print(f"Error reading file: {e}", file=sys.stderr)
            sys.exit(1)

        issues = agent.review(code, language=language)
        print(f"=== Code Review ({language}) ===")
        if not issues:
            print("  No issues found.")
        else:
            for issue in issues:
                icon = {"warning": "⚠", "error": "✗", "info": "ℹ", "style": "💡"}.get(issue.get('type', ''), '?')
                print(f"  {icon} [{issue.get('type', '?').upper()}] Line {issue.get('line', 0)}: {issue.get('message', '')}")

    elif args.refactor:
        print(f"[build] Refactoring code from: {args.refactor} (strategy: {args.strategy})\n")
        try:
            with open(args.refactor, 'r') as f:
                code = f.read()
        except Exception as e:
            print(f"Error reading file: {e}", file=sys.stderr)
            sys.exit(1)

        result = agent.refactor(code, strategy=args.strategy or "extract")
        print(f"=== Refactored Code ===\n{result}")

    else:
        print(f"[build] Generating {language} code for: {args.prompt}\n")
        code = agent.generate(args.prompt, language=language)
        print(f"=== Generated {language} Code ===\n{code}")


